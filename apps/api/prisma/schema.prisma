generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/* =======================
  ENUMS
======================= */

enum UserRole {
  mentee
  mentor
  admin

  @@map("user_role")
}

enum UserStatus {
  active
  inactive
  pending_approval
  pending_review
  approved
  rejected
  banned
  suspended
  deleted

  @@map("user_status")
}

enum MenteePreferredSessionType {
  online
  in_person

  @@map("mentee_preferred_session_type")
}

enum LogsActionType {
  create
  read
  update
  delete
  signin
  signup
  signout
  resend_email_confirmation

  @@map("logs_action_type")
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
  DELETED

  @@map("booking_status")
}

enum NotificationType {
  BOOKING
  SESSION
  MESSAGE
  ANNOUNCEMENT

  @@map("notification_type")
}

enum NotificationStatus {
  UNREAD
  READ
  DELETED

  @@map("notification_status")
}

/* =======================
  MODELS
======================= */

model User {
  id                  String     @id @default(uuid()) @map("id")
  firstName           String     @map("first_name")
  middleName          String?    @map("middle_name")
  lastName            String     @map("last_name")
  suffix              String?
  email               String     @unique
  country             String?
  timezone            String?
  language            String?
  phoneNumber         String?    @unique         @map("phone_number")        
  hashPassword        String                     @map("hash_password")
  isProfileComplete   Boolean    @default(true)  @map("is_profile_complete")
  isMentorProfileComplete   Boolean    @default(true)  @map("is_mentor_profile_complete")
  isMentorApproved    Boolean    @default(false) @map("is_mentor_approved")
  role                UserRole
  status              UserStatus
  createdById         String?                    @map("created_by_id")
  updatedById         String?                    @map("updated_by_id")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt      @map("updated_at")

  // Relations
  createdBy               User?                 @relation("user_created_by", fields: [createdById], references: [id])
  updatedBy               User?                 @relation("user_updated_by", fields: [updatedById], references: [id])
  createdUsers            User[]                @relation("user_created_by")
  updatedUsers            User[]                @relation("user_updated_by")
  menteeProfiles          MenteeProfile[]       @relation("mentee_base_user")
  mentorProfiles          MentorProfile[]       @relation("mentor_base_user")
  menteeProfilesUpdated   MenteeProfile[]       @relation("mentee_updated_by")
  mentorProfilesUpdated   MentorProfile[]       @relation("mentor_updated_by")
  avatarAttachments       AvatarAttachment[]
  documentAttachments     DocumentAttachment[]

  logsCreated      Logs[]         @relation("logs_created_by")
  logsUpdated      Logs[]         @relation("logs_updated_by")
  notifications    Notification[]
  bookingsAsMentee Booking[]      @relation("MenteeBookings")
  bookingsAsMentor Booking[]      @relation("MentorBookings")

  @@map("users")
}

model MenteeProfile {
  id                   String                     @id @default(uuid())
  userId               String                     @unique @map("user_id")
  bio                  String?
  learningGoals        String[]                   @map("learning_goals")
  areasOfInterest      String[]                   @map("areas_of_interest")
  preferredSessionType MenteePreferredSessionType @map("preferred_session_type")
  availability         Json
  updatedById          String?                    @map("updated_by_id")
  updatedAt            DateTime                   @updatedAt @map("updated_at")

  user                 User     @relation("mentee_base_user", fields: [userId], references: [id])
  updatedBy            User?    @relation("mentee_updated_by", fields: [updatedById], references: [id])

  @@map("mentee_profiles")
}

model MentorProfile {
  id                String    @id @default(uuid())
  userId            String    @unique @map("user_id")
  areasOfExpertise  String[]  @map("areas_of_expertise")
  yearsOfExperience Int?      @map("years_of_experience")
  linkedInUrl       String?   @map("linkedin_url")
  bio               String?
  skills            String[]
  sessionRate       Float?    @map("session_rate")
  availability      Json
  updatedById       String?   @map("updated_by_id")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user              User      @relation("mentor_base_user", fields: [userId], references: [id])
  updatedBy         User?     @relation("mentor_updated_by", fields: [updatedById], references: [id])

  @@map("mentor_profiles")
}

model AvatarAttachment {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  bucketName        String  @map("bucket_name")
  storagePath       String  @map("storage_path")
  publicUrl         String  @map("public_url")
  fileType          String  @map("file_type")
  fileSize          Int     @map("file_size")
  fileName          String  @map("file_name")

  user User @relation(fields: [userId], references: [id])

  @@map("avatar_attachments")
}

model DocumentAttachment {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  bucketName   String   @map("bucket_name")
  storagePath  String   @map("storage_path")
  publicUrl    String   @map("public_url")
  fileType     String   @map("file_type")
  fileSize     Int      @map("file_size")
  fileName     String   @map("file_name")

  user         User     @relation(fields: [userId], references: [id])

  @@map("document_attachments")
}

model Logs {
  id          String          @id @default(uuid())
  actionType  LogsActionType  @map("action_type")
  targetId    String          @map("target_id")
  details     String
  metadata    Json?
  ipAddress   String          @map("ip_address")
  userAgent   String          @map("user_agent")
  createdById String?         @map("created_by_id")
  updatedById String?         @map("updated_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  createdBy   User?           @relation("logs_created_by", fields: [createdById], references: [id])
  updatedBy   User?           @relation("logs_updated_by", fields: [updatedById], references: [id])

  @@map("logs")
}

model Notification {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  title       String
  message     String
  type        NotificationType
  status      NotificationStatus @default(UNREAD)
  referenceId String?            @map("reference_id")
  readAt      DateTime?          @map("read_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  user        User               @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Booking {
  id              String        @id @default(uuid())
  menteeId        String        @map("mentee_id")
  mentorId        String        @map("mentor_id")
  sessionDateTime DateTime      @map("session_date_time")
  status          BookingStatus @default(PENDING)
  sessionLink     String?       @map("session_link")
  notes           String?
  isDeleted       Boolean       @default(false) @map("is_deleted")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  mentee          User          @relation("MenteeBookings", fields: [menteeId], references: [id])
  mentor          User          @relation("MentorBookings", fields: [mentorId], references: [id])

  @@map("bookings")
}
