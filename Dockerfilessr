FROM node:20-alpine AS builder

WORKDIR /build

# Copy package files first for better layer caching
COPY package*.json ./

# Install dependencies
RUN npm ci --legacy-peer-deps

# Copy the rest of the source code
COPY . .

# Build the Angular SSR application
RUN npx nx build landing-page

FROM node:20-alpine AS runner

WORKDIR /app
# Copy the entire build output to /app
COPY --from=builder /build/dist/apps/landing-page .

# Copy node_modules to /app/node_modules
COPY --from=builder /build/node_modules ./node_modules

# Clean up unnecessary files to reduce image size
RUN rm -rf /tmp/* /var/cache/apk/* /var/tmp/*

# Run the server
CMD ["node", "server/server.mjs"]